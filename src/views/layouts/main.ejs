<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'Nexus' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@300;400;500&family=DM+Sans:opsz,wght@9..40,300;9..40,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>

  <div class="noise"></div>

  <header class="site-header">
    <a href="/" class="logo">
      <span class="logo-mark">&#9670;</span>
      <span class="logo-text">NEXUS</span>
    </a>
    <nav class="site-nav">
      <a href="/api/auth/login">Login</a>
      <a href="/api/auth/register" class="nav-cta">Register</a>
    </nav>
  </header>

  <main class="site-main">
    <%- body %>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <span class="footer-brand">&#9670; NEXUS</span>
      <span class="footer-copy">&copy; <%= new Date().getFullYear() %> &mdash; All rights reserved.</span>
      <div class="footer-links">
        <a href="#">Privacy</a>
        <a href="#">Terms</a>
      </div>
    </div>
  </footer>

</body>
</html>
